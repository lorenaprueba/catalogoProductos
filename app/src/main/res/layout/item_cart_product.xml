<?xml version="1.0" encoding="utf-8"?>
<!-- Layout para cada producto en la lista del carrito -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Nombre del producto -->
    <TextView
        android:id="@+id/productName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nombre del Producto"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Precio unitario del producto -->
    <TextView
        android:id="@+id/productPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="S/ 0.00"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/productName"
        android:layout_marginTop="4dp" />

    <!-- Botón para disminuir cantidad -->
    <Button
        android:id="@+id/buttonDecrease"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="-"
        android:textSize="18sp"
        android:padding="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/productPrice"
        android:layout_marginTop="8dp" />

    <!-- Mostrador de cantidad actual -->
    <TextView
        android:id="@+id/quantityText"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="1"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:minWidth="40dp"
        app:layout_constraintStart_toEndOf="@id/buttonDecrease"
        app:layout_constraintTop_toBottomOf="@id/productPrice"
        android:layout_marginTop="8dp" />

    <!-- Botón para aumentar cantidad -->
    <Button
        android:id="@+id/buttonIncrease"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="+"
        android:textSize="18sp"
        android:padding="0dp"
        app:layout_constraintStart_toEndOf="@id/quantityText"
        app:layout_constraintTop_toBottomOf="@id/productPrice"
        android:layout_marginTop="8dp" />

    <!-- Botón para eliminar el producto del carrito (con ícono de papelera) -->
    <Button
        android:id="@+id/buttonRemove"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="Eliminar"
        android:textSize="12sp"
        android:layout_marginStart="8dp"
        app:icon="@drawable/ic_delete"
        app:iconGravity="textStart"
        app:layout_constraintStart_toEndOf="@id/buttonIncrease"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/productPrice"
        android:layout_marginTop="8dp" />

    <!-- Precio total del producto (cantidad * precio unitario) -->
    <TextView
        android:id="@+id/totalPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total: S/ 0.00"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/price_green"
        android:gravity="end"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonDecrease"
        android:layout_marginTop="12dp" />

    <!-- Línea divisoria entre productos -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_gray"
        app:layout_constraintTop_toBottomOf="@id/totalPrice"
        android:layout_marginTop="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
